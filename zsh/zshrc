export DOTFILES="${${(%):-%x}:A:h:h}"
export SHELDON_CONFIG_DIR="$DOTFILES/sheldon"

# Periodically prompt to update sheldon plugins
if (( $+commands[sheldon] )); then
  local _sheldon_stamp="${XDG_CACHE_HOME:-$HOME/.cache}/sheldon_last_update"
  local _sheldon_days=14
  local _sheldon_now=$(date +%s)
  local _sheldon_last=$(cat "$_sheldon_stamp" 2>/dev/null || echo 0)
  if (( _sheldon_now - _sheldon_last > _sheldon_days * 86400 )); then
    echo "sheldon plugins haven't been updated in $_sheldon_days days. Update? [y/N]"
    if read -q; then
      echo
      sheldon lock --update && echo "$_sheldon_now" > "$_sheldon_stamp"
    else
      echo
      echo "$_sheldon_now" > "$_sheldon_stamp"
    fi
  fi
fi

# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# Sheldon plugin manager
if (( $+commands[sheldon] )); then
  eval "$(sheldon source)"
else
  echo 'sheldon is not installed. To set up:'
  echo ''
  case "$OSTYPE" in
    darwin*) echo '  1. brew install sheldon' ;;
    linux*)  echo '  1. pacman -S sheldon' ;;
  esac
  echo '  2. sheldon lock    # fetch plugins'
  echo '  3. exec zsh        # restart shell'
fi

# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

# Import local configurations
[[ -f ~/.zshrc.local ]] && source ~/.zshrc.local
